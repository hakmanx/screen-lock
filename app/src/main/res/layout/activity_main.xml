<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B0B0F"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="IronLink"
        android:textColor="#F3F3F3"
        android:textSize="28sp"
        android:textStyle="bold"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:id="@+id/selectedCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#17171D"
        android:padding="14dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/txtSelectedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Доверенное устройство"
            android:textColor="#C8C8CE"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtSelected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Не выбрано"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingTop="6dp" />

        <TextView
            android:id="@+id/txtMonitorState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Мониторинг выключен"
            android:textColor="#FF6B6B"
            android:textSize="14sp"
            android:paddingTop="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnToggleMonitoring"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Включить мониторинг"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#B63A3A" />

    <Button
        android:id="@+id/btnOpenSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Настройки"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A33"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/txtListTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Доступные устройства"
        android:textColor="#E8E8EA"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingTop="16dp"
        android:paddingBottom="10dp" />

    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#26262E"
        android:dividerHeight="1dp" />
</LinearLayout>
