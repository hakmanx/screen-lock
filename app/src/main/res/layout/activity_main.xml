<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IronLink"
            android:textColor="#F3F3F3"
            android:textSize="28sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <LinearLayout
            android:id="@+id/selectedCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#17171D"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txtSelectedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выбранные устройства"
                android:textColor="#C8C8CE"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtSelected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Нет выбранных устройств"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingTop="6dp" />

            <TextView
                android:id="@+id/txtMonitorState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Защита неактивна"
                android:textColor="#FF6B6B"
                android:textSize="14sp"
                android:paddingTop="8dp" />

            <TextView
                android:id="@+id/txtDelayValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Задержка блокировки: 0 сек"
                android:textColor="#C8C8CE"
                android:textSize="14sp"
                android:paddingTop="6dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnToggleMonitoring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Включить защиту"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B63A3A" />

        <Button
            android:id="@+id/btnChooseDevice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выбрать Bluetooth-устройства"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A33"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnOpenJournal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Журнал"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A33"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Настройки"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A33"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Блокировка сработает при отключении любого выбранного устройства."
            android:textColor="#9A9AA2"
            android:textSize="13sp"
            android:paddingTop="18dp" />

    </LinearLayout>
</ScrollView>
