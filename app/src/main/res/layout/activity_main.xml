<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_guard_screen"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_guardlink_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/app_name"
                android:textColor="@color/guard_text_primary"
                android:textSize="27sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_guard_hero_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="22dp">

            <ImageView
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_guardlink_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Статус защиты"
                android:textColor="@color/guard_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtMonitorState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Защита неактивна"
                android:textColor="@color/guard_text_muted"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="Блокировка экрана при разрыве доверенного Bluetooth-соединения"
                android:textColor="@color/guard_text_secondary"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="18dp"
                android:background="@color/guard_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Подключено к устройству"
                android:textColor="@color/guard_text_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtSelected"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_guard_button_secondary"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:text="Нет выбранного устройства"
                android:textColor="@color/guard_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDelaySummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Блокировка при разрыве • Задержка: 0 сек"
                android:textColor="@color/guard_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnToggleMonitoring"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_guard_button_primary"
            android:backgroundTint="@null"
            android:text="Включить защиту"
            android:textAllCaps="false"
            android:textColor="@color/guard_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnChooseDevice"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_guard_button_secondary"
            android:backgroundTint="@null"
            android:text="Выбрать устройство"
            android:textAllCaps="false"
            android:textColor="@color/guard_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpenLogs"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_guard_button_secondary"
            android:backgroundTint="@null"
            android:text="Журнал событий"
            android:textAllCaps="false"
            android:textColor="@color/guard_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_guard_button_secondary"
            android:backgroundTint="@null"
            android:text="Правила и настройки"
            android:textAllCaps="false"
            android:textColor="@color/guard_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
