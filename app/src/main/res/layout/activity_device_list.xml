<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B0B0F"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bluetooth-устройства"
        android:textColor="#F3F3F3"
        android:textSize="26sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/txtDeviceSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выберите одно или несколько Bluetooth-устройств."
        android:textColor="#C8C8CE"
        android:textSize="14sp"
        android:paddingBottom="10dp" />

    <ListView
        android:id="@+id/listViewDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:cacheColorHint="#00000000"
        android:divider="#26262E"
        android:dividerHeight="1dp" />

    <Button
        android:id="@+id/btnSaveDevices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сохранить выбор"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#B63A3A"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnClearDevices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Очистить выбор"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A33"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnBackDevices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Назад"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A33"
        android:layout_marginTop="8dp" />

</LinearLayout>
