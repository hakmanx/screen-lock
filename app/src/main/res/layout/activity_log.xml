<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B0B0F"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Журнал"
        android:textColor="#F3F3F3"
        android:textSize="26sp"
        android:textStyle="bold"
        android:paddingBottom="10dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#17171D"
        android:padding="12dp">

        <TextView
            android:id="@+id/txtLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Журнал пуст"
            android:textColor="#E8E8EA"
            android:textSize="13sp"
            android:fontFamily="monospace" />

    </ScrollView>

    <Button
        android:id="@+id/btnCopyLogs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Скопировать журнал"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A33"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnClearLogsScreen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Очистить журнал"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#B63A3A"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnBackLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Назад"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A33"
        android:layout_marginTop="8dp" />

</LinearLayout>
