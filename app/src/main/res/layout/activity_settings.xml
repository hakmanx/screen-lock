<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtSettingsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IronLink — настройки"
            android:textColor="#F3F3F3"
            android:textSize="26sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#17171D"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Управление"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnEnableAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Включить Device Admin"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#8E2B2B"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnExportLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Выгрузить логи"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B63A3A"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnClearLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Очистить логи"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2A2A33"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#17171D"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Примечание"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Переключение режима полета, Wi-Fi и мобильных данных обычному приложению недоступно. Для этого нужны системные или корпоративные привилегии."
                android:textColor="#C8C8CE"
                android:textSize="14sp"
                android:paddingTop="10dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
