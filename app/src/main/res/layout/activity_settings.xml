<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Настройки"
            android:textColor="#F3F3F3"
            android:textSize="26sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/txtLockDelayValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Текущая задержка: 0 сек"
            android:textColor="#C8C8CE"
            android:textSize="15sp"
            android:paddingBottom="10dp" />

        <Button
            android:id="@+id/btnEnableAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Включить Device Admin"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B63A3A" />

        <Button
            android:id="@+id/btnSetLockDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Задержка блокировки"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A33"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnExportLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выгрузить журнал"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A33"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnClearLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Очистить журнал"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A33"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnBackSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Назад"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A33"
            android:layout_marginTop="10dp" />

    </LinearLayout>
</ScrollView>
