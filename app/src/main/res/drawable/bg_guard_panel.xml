<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#221A22"
                android:centerColor="#16131A"
                android:endColor="#0F0D13" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#4CF04A55" />
        </shape>
    </item>

    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#14FFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <item
        android:gravity="bottom"
        android:left="10dp"
        android:right="10dp"
        android:bottom="8dp">
        <shape android:shape="rectangle">
            <size android:height="50dp" />
            <gradient
                android:angle="90"
                android:startColor="#00FF4651"
                android:centerColor="#12FF4651"
                android:endColor="#00FF4651" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
