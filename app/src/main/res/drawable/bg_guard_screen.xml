<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/guard_black"
                android:centerColor="#0E0910"
                android:endColor="@color/guard_black" />
        </shape>
    </item>

    <item
        android:left="-140dp"
        android:top="-120dp"
        android:right="60dp"
        android:bottom="340dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="320dp"
                android:centerX="40%"
                android:centerY="30%"
                android:startColor="#55FF3B30"
                android:centerColor="#22C1121F"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item
        android:left="120dp"
        android:top="380dp"
        android:right="-140dp"
        android:bottom="-120dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="340dp"
                android:centerX="70%"
                android:centerY="70%"
                android:startColor="#22FF3B30"
                android:centerColor="#14C1121F"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item
        android:left="-60dp"
        android:top="70dp"
        android:right="-60dp"
        android:bottom="560dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#00FF3B30"
                android:centerColor="#22FF3B30"
                android:endColor="#00FF3B30" />
            <corners android:radius="200dp" />
        </shape>
    </item>

    <item
        android:left="-50dp"
        android:top="620dp"
        android:right="-50dp"
        android:bottom="40dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#00FF3B30"
                android:centerColor="#18FF3B30"
                android:endColor="#00FF3B30" />
            <corners android:radius="200dp" />
        </shape>
    </item>

</layer-list>
