<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#060608"
                android:centerColor="#0A0810"
                android:endColor="#13070B" />
        </shape>
    </item>

    <item android:gravity="top|start">
        <shape android:shape="oval">
            <size
                android:width="280dp"
                android:height="280dp" />
            <gradient
                android:type="radial"
                android:centerX="35%"
                android:centerY="30%"
                android:gradientRadius="190dp"
                android:startColor="#1AFF4F5B"
                android:centerColor="#0CF63E4B"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item android:gravity="bottom|end">
        <shape android:shape="oval">
            <size
                android:width="360dp"
                android:height="360dp" />
            <gradient
                android:type="radial"
                android:centerX="65%"
                android:centerY="70%"
                android:gradientRadius="230dp"
                android:startColor="#26C70E1C"
                android:centerColor="#127A0812"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <size android:height="180dp" />
            <gradient
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#14000000"
                android:endColor="#28000000" />
        </shape>
    </item>
</layer-list>
