<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#3B1319"
                android:centerColor="#241218"
                android:endColor="#171117" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#6AF04B56" />
        </shape>
    </item>

    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#18FFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <item
        android:gravity="start|center_vertical"
        android:left="8dp">
        <shape android:shape="oval">
            <size
                android:width="52dp"
                android:height="52dp" />
            <gradient
                android:angle="315"
                android:startColor="#F34A55"
                android:endColor="#6D0C14" />
        </shape>
    </item>
</layer-list>
