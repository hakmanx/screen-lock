<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#27202A"
                android:centerColor="#18141C"
                android:endColor="#100E14" />
            <corners android:radius="30dp" />
            <stroke
                android:width="1dp"
                android:color="#5CE14954" />
        </shape>
    </item>

    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#16FFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="30dp" />
        </shape>
    </item>

    <item
        android:gravity="bottom"
        android:bottom="10dp"
        android:left="14dp"
        android:right="14dp">
        <shape android:shape="rectangle">
            <size android:height="72dp" />
            <gradient
                android:angle="90"
                android:startColor="#00FF3543"
                android:centerColor="#14FF3543"
                android:endColor="#00FF3543" />
            <corners android:radius="26dp" />
        </shape>
    </item>

    <item
        android:left="22dp"
        android:top="22dp"
        android:right="22dp"
        android:bottom="22dp">
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <padding
                android:left="0dp"
                android:top="0dp"
                android:right="0dp"
                android:bottom="0dp" />
        </shape>
    </item>
</layer-list>
